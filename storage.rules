rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /news_images/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 8 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
    match /news_audio/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 15 * 1024 * 1024
                   && request.resource.contentType.matches('audio/.*');
    }
    match /news_videos/{fileName} {
      allow read: if true;
      // 25MB ceiling mirrors MAX_VIDEO_BYTES in src/utils/video.js — duration
      // (90s) is checked client-side since Storage rules can't read video
      // metadata; this size cap is the server-side backstop against someone
      // bypassing the client check and uploading something much larger.
      allow write: if request.auth != null
                   && request.resource.size < 25 * 1024 * 1024
                   && request.resource.contentType.matches('video/.*');
    }
    match /profile_photos/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 4 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
